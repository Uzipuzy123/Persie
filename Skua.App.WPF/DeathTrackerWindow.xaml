<Window x:Class="Skua.App.WPF.StatTrackerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stat Tracker"
        Height="430" Width="260"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Left="0" Top="0"
        Background="#1a237e"
        FontFamily="Segoe UI">
    <StackPanel>

        <!-- Header -->
        <Border Background="#283593" Padding="0,9">
            <TextBlock Text="STAT TRACKER" Foreground="White" FontSize="11"
                       FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>

        <!-- Stat Rows -->
        <StackPanel Margin="8,6,8,0">

            <!-- Deaths -->
            <Border Background="#1e2d8f" CornerRadius="3" Margin="0,3" Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Deaths" Foreground="#90CAF9"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Deaths}" Foreground="White"
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="R" Command="{Binding ResetDeathsCommand}"
                            Width="26" Height="22" Padding="0"
                            Background="#5c6bc0" Foreground="White" BorderThickness="0" FontSize="11"/>
                </Grid>
            </Border>

            <!-- Kills -->
            <Border Background="#1e2d8f" CornerRadius="3" Margin="0,3" Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Kills" Foreground="#90CAF9"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Kills}" Foreground="White"
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="R" Command="{Binding ResetKillsCommand}"
                            Width="26" Height="22" Padding="0"
                            Background="#5c6bc0" Foreground="White" BorderThickness="0" FontSize="11"/>
                </Grid>
            </Border>

            <!-- Dmg Taken -->
            <Border Background="#1e2d8f" CornerRadius="3" Margin="0,3" Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Dmg Taken" Foreground="#90CAF9"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding DamageTakenDisplay}" Foreground="White"
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="R" Command="{Binding ResetDamageTakenCommand}"
                            Width="26" Height="22" Padding="0"
                            Background="#5c6bc0" Foreground="White" BorderThickness="0" FontSize="11"/>
                </Grid>
            </Border>

            <!-- Dmg Dealt -->
            <Border Background="#1e2d8f" CornerRadius="3" Margin="0,3" Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Dmg Dealt" Foreground="#90CAF9"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding DamageDealtDisplay}" Foreground="White"
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="R" Command="{Binding ResetDamageDealtCommand}"
                            Width="26" Height="22" Padding="0"
                            Background="#5c6bc0" Foreground="White" BorderThickness="0" FontSize="11"/>
                </Grid>
            </Border>

            <!-- Heals -->
            <Border Background="#1e2d8f" CornerRadius="3" Margin="0,3" Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Heals" Foreground="#90CAF9"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding HealsReceivedDisplay}" Foreground="White"
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="R" Command="{Binding ResetHealsCommand}"
                            Width="26" Height="22" Padding="0"
                            Background="#5c6bc0" Foreground="White" BorderThickness="0" FontSize="11"/>
                </Grid>
            </Border>

            <!-- Crits -->
            <Border Background="#1e2d8f" CornerRadius="3" Margin="0,3" Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Crits" Foreground="#90CAF9"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Crits}" Foreground="White"
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="R" Command="{Binding ResetCritsCommand}"
                            Width="26" Height="22" Padding="0"
                            Background="#5c6bc0" Foreground="White" BorderThickness="0" FontSize="11"/>
                </Grid>
            </Border>

            <!-- Dodges -->
            <Border Background="#1e2d8f" CornerRadius="3" Margin="0,3" Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Dodges" Foreground="#90CAF9"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Dodges}" Foreground="White"
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="R" Command="{Binding ResetDodgesCommand}"
                            Width="26" Height="22" Padding="0"
                            Background="#5c6bc0" Foreground="White" BorderThickness="0" FontSize="11"/>
                </Grid>
            </Border>

        </StackPanel>

        <Separator Background="#283593" Margin="8,10,8,6"/>

        <Grid Margin="8,0,8,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Reset All" Command="{Binding ResetAllCommand}"
                    Height="28" Background="#3949ab" Foreground="White" BorderThickness="0"
                    FontSize="11" FontWeight="SemiBold"/>
            <Button Grid.Column="2" Content="Skills" Click="SkillsButton_Click"
                    Height="28" Background="#283593" Foreground="White" BorderThickness="0"
                    FontSize="11" FontWeight="SemiBold"/>
        </Grid>

    </StackPanel>
</Window>
