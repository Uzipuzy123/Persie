<UserControl
    x:Class="Skua.WPF.UserControls.MainMenuUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Skua.WPF.UserControls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vms="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core"
    d:DataContext="{d:DesignInstance vms:MainMenuViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Background="#1a237e">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">

            <!-- Stats toggle -->
            <ToggleButton
                Height="36"
                Padding="14,0"
                Content="Stats"
                IsChecked="{Binding IsStatTrackerOpen, Mode=TwoWay}"
                Style="{StaticResource MaterialDesignFlatButton}"
                Foreground="White" />

            <!-- PVP FPS button -->
            <Button
                Height="36"
                Padding="14,0"
                Foreground="White"
                Background="Transparent"
                BorderThickness="0"
                Content="PVP FPS"
                Command="{Binding MainMenuItems[8].Command}"
                Style="{StaticResource MaterialDesignFlatButton}" />

            <!-- Quality button -->
            <Button
                Height="36"
                Padding="14,0"
                Foreground="White"
                Background="Transparent"
                BorderThickness="0"
                Content="Quality"
                Command="{Binding MainMenuItems[9].Command}"
                Style="{StaticResource MaterialDesignFlatButton}" />

        </StackPanel>
    </Grid>
</UserControl>
