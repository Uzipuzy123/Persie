<wpf:CustomWindow
    x:Class="Skua.App.WPF.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Skua.WPF.UserControls;assembly=Skua.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Skua.App.WPF"
    xmlns:materialdesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tb="http://www.hardcodet.net/taskbar"
    xmlns:vms="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core"
    xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
    xmlns:wpf="clr-namespace:Skua.WPF;assembly=Skua.WPF"
    Title="{Binding Title}"
    Width="948"
    Height="660"
    d:DataContext="{d:DesignInstance vms:MainViewModel}"
    Style="{StaticResource CustomWindow}"
    mc:Ignorable="d">
    <Grid>
        <DockPanel>
            <!-- Top nav bar -->
            <controls:MainMenuUserControl Panel.ZIndex="10" DockPanel.Dock="Top" />

            <!-- Chrome-style status bar -->
            <Border DockPanel.Dock="Bottom" Height="20"
                    Background="#F1F3F4" BorderBrush="#DADCE0" BorderThickness="0,1,0,0">
                <Grid Margin="10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="#23A55A"
                                 Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Connected" Foreground="#5F6368"
                                   FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="PVP Hero 2.0"
                               Foreground="#5F6368" FontSize="10"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Game window fills remaining space -->
            <controls:GameContainerUserControl />
        </DockPanel>

        <tb:TaskbarIcon
            x:Name="NotifyIcon"
            DoubleClickCommand="{Binding ShowMainWindowCommand}"
            IconSource="SkuaIcon.ico"
            MenuActivation="RightClick"
            ToolTipText="PVP Hero 2.0"
            Visibility="Visible">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Click="MenuItem_Click" Header="Toggle Bot" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</wpf:CustomWindow>
