<Window x:Class="Skua.App.WPF.StatTrackerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stat Tracker"
        Height="295" Width="270"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Left="0" Top="0"
        Background="#1a237e">
    <StackPanel Margin="12,10,12,10">
        <DockPanel Margin="0,4">
            <Button DockPanel.Dock="Right" Content="R" Command="{Binding ResetDeathsCommand}"
                    Width="24" Height="22" Background="#3949ab" Foreground="White" BorderThickness="0" FontSize="11"/>
            <TextBlock Text="{Binding Deaths, StringFormat='Deaths: {0}'}"
                       Foreground="White" FontSize="13" VerticalAlignment="Center"/>
        </DockPanel>
        <DockPanel Margin="0,4">
            <Button DockPanel.Dock="Right" Content="R" Command="{Binding ResetKillsCommand}"
                    Width="24" Height="22" Background="#3949ab" Foreground="White" BorderThickness="0" FontSize="11"/>
            <TextBlock Text="{Binding Kills, StringFormat='Kills: {0}'}"
                       Foreground="White" FontSize="13" VerticalAlignment="Center"/>
        </DockPanel>
        <DockPanel Margin="0,4">
            <Button DockPanel.Dock="Right" Content="R" Command="{Binding ResetDamageTakenCommand}"
                    Width="24" Height="22" Background="#3949ab" Foreground="White" BorderThickness="0" FontSize="11"/>
            <TextBlock Text="{Binding DamageTaken, StringFormat='Dmg Taken: {0:N0}'}"
                       Foreground="White" FontSize="13" VerticalAlignment="Center"/>
        </DockPanel>
        <DockPanel Margin="0,4">
            <Button DockPanel.Dock="Right" Content="R" Command="{Binding ResetDamageDealtCommand}"
                    Width="24" Height="22" Background="#3949ab" Foreground="White" BorderThickness="0" FontSize="11"/>
            <TextBlock Text="{Binding DamageDealt, StringFormat='Dmg Dealt: {0:N0}'}"
                       Foreground="White" FontSize="13" VerticalAlignment="Center"/>
        </DockPanel>
        <DockPanel Margin="0,4">
            <Button DockPanel.Dock="Right" Content="R" Command="{Binding ResetDamageDodgedCommand}"
                    Width="24" Height="22" Background="#3949ab" Foreground="White" BorderThickness="0" FontSize="11"/>
            <TextBlock Text="{Binding DamageDodged, StringFormat='Dmg Dodged: {0}'}"
                       Foreground="White" FontSize="13" VerticalAlignment="Center"/>
        </DockPanel>
        <DockPanel Margin="0,4">
            <Button DockPanel.Dock="Right" Content="R" Command="{Binding ResetHealsCommand}"
                    Width="24" Height="22" Background="#3949ab" Foreground="White" BorderThickness="0" FontSize="11"/>
            <TextBlock Text="{Binding HealsReceived, StringFormat='Heals: {0:N0}'}"
                       Foreground="White" FontSize="13" VerticalAlignment="Center"/>
        </DockPanel>
        <Separator Background="#3949ab" Margin="0,8,0,8"/>
        <Button Content="Reset All" Command="{Binding ResetAllCommand}"
                HorizontalAlignment="Center"
                Padding="20,4"
                Background="#3949ab" Foreground="White" BorderThickness="0" FontSize="12"/>
    </StackPanel>
</Window>
