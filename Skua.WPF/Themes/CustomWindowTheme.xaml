<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Skua.WPF"
    xmlns:materialdesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- ── Window control button base ──────────────────────────────────────── -->
    <Style x:Key="ChromeWinBtn" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{DynamicResource ThemeChromeIcon}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Width"           Value="46"/>
        <Setter Property="Height"          Value="36"/>
        <Setter Property="Cursor"          Value="Arrow"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeChromeNavHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeChromeNavPressed}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Close button: turns red on hover ─────────────────────────────────── -->
    <Style x:Key="ChromeCloseBtn" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{DynamicResource ThemeChromeIcon}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Width"           Value="46"/>
        <Setter Property="Height"          Value="36"/>
        <Setter Property="Cursor"          Value="Arrow"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#F1707A"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Main window style ──────────────────────────────────────────────── -->
    <Style x:Key="CustomWindow" TargetType="{x:Type local:CustomWindow}">
        <Setter Property="Background" Value="Black"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeChromeTitle}"/>
        <Setter Property="WindowChrome.WindowChrome">
            <Setter.Value>
                <WindowChrome
                    CaptionHeight="36"
                    CornerRadius="0"
                    GlassFrameThickness="0"
                    ResizeBorderThickness="4"/>
            </Setter.Value>
        </Setter>
        <Setter Property="WindowStyle" Value="None"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:CustomWindow">
                    <Border BorderBrush="{DynamicResource ThemeChromeBorder}" BorderThickness="1">
                        <DockPanel Background="Black">

                            <!-- ── Chrome tab strip ─────────────────────────── -->
                            <Border Height="36" DockPanel.Dock="Top"
                                    Background="{DynamicResource ThemeChromeBg}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Tab strip -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                VerticalAlignment="Bottom">

                                        <!-- Active tab pill -->
                                        <Border Background="{DynamicResource ThemeChromeActiveTab}"
                                                CornerRadius="8,8,0,0"
                                                Margin="8,4,0,0" Padding="10,0,6,0"
                                                MinWidth="200" Height="32">
                                            <Grid VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Favicon (gold AQW circle — stays gold, it's branding) -->
                                                <Ellipse Grid.Column="0" Width="14" Height="14"
                                                         VerticalAlignment="Center" Margin="0,0,7,0">
                                                    <Ellipse.Fill>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#D4B050" Offset="0"/>
                                                            <GradientStop Color="#8B5E15" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Ellipse.Fill>
                                                </Ellipse>

                                                <!-- Tab title -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{TemplateBinding Title}"
                                                           Foreground="{DynamicResource ThemeChromeTitle}"
                                                           FontFamily="Segoe UI" FontSize="12"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <!-- Tab × -->
                                                <Border Grid.Column="2" Width="18" Height="18"
                                                        CornerRadius="9" Margin="6,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="✕" FontSize="9"
                                                               Foreground="{DynamicResource ThemeChromeIcon}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <!-- New-tab + button -->
                                        <Border Width="28" Height="28" CornerRadius="14"
                                                Margin="6,0,0,4" VerticalAlignment="Center">
                                            <TextBlock Text="+" FontSize="18" FontWeight="Light"
                                                       Foreground="{DynamicResource ThemeChromeIcon}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Window controls -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Top" Height="36">
                                        <Button x:Name="PART_Minimize"
                                                Style="{StaticResource ChromeWinBtn}"
                                                WindowChrome.IsHitTestVisibleInChrome="True"
                                                Content="—"/>
                                        <Button x:Name="PART_Maximize"
                                                Style="{StaticResource ChromeWinBtn}"
                                                WindowChrome.IsHitTestVisibleInChrome="True"
                                                Content="□"/>
                                        <Button x:Name="PART_Close"
                                                Style="{StaticResource ChromeCloseBtn}"
                                                WindowChrome.IsHitTestVisibleInChrome="True"
                                                Content="✕"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Content area -->
                            <ContentPresenter Content="{TemplateBinding Content}"/>
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
