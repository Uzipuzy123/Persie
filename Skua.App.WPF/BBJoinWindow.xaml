<Window x:Class="Skua.App.WPF.BBJoinWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BB Join"
        Height="360" Width="300"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False"
        Icon="{x:Null}"
        Background="{DynamicResource ThemeBg}"
        FontFamily="Segoe UI">

    <Grid>
        <!-- Ornate border -->
        <Border Margin="10" BorderThickness="3" CornerRadius="4"
                BorderBrush="{DynamicResource ThemeBorderBrush}">

            <StackPanel Background="{DynamicResource ThemeBg}">

                <!-- Title (drag handle) -->
                <Border Background="Transparent" Cursor="SizeAll"
                        MouseLeftButtonDown="Window_MouseDown" Padding="0,14,0,6">
                    <TextBlock Text="BB Join"
                               FontFamily="Georgia" FontStyle="Italic" FontSize="19"
                               Foreground="{DynamicResource ThemeTitle}" HorizontalAlignment="Center"/>
                </Border>

                <!-- Divider -->
                <Border Height="1" Margin="16,0,16,10"
                        Background="{DynamicResource ThemeDividerBrush}"/>

                <!-- Description -->
                <TextBlock Foreground="{DynamicResource ThemeSubLabel}" FontSize="10"
                           TextWrapping="Wrap" Margin="16,0,16,12" LineHeight="15">
                    Joins a Bludrutbrawl room. The number is hidden from all participants via packet masking.
                </TextBlock>

                <!-- Masked room pill -->
                <Border Margin="14,0,14,16" CornerRadius="4" Padding="12,8"
                        BorderThickness="1" BorderBrush="{DynamicResource ThemeSectionDiv}"
                        Background="{DynamicResource ThemeRowBg}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="7" Height="7" Fill="#3A3A3A"
                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="MaskedRoomLabel"
                                   Text="bludrutbrawl-????"
                                   Foreground="{DynamicResource ThemeSubLabel}"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Section divider -->
                <Border Height="1" Margin="0,0,0,14"
                        Background="{DynamicResource ThemeSectionDivBrush}"/>

                <!-- Room # input -->
                <Grid Margin="14,0,14,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Room #"
                               Foreground="{DynamicResource ThemeSubLabel}" FontSize="11"
                               VerticalAlignment="Center"/>
                    <Border Grid.Column="1" BorderThickness="1" CornerRadius="3" Padding="8,5"
                            Background="{DynamicResource ThemeRowBg}"
                            BorderBrush="{DynamicResource ThemeBorderBrush}">
                        <PasswordBox x:Name="RoomNumberBox"
                                     Background="Transparent"
                                     Foreground="{DynamicResource ThemeRowLabel}"
                                     BorderThickness="0" Padding="0"
                                     FontSize="12" FontFamily="Consolas"
                                     CaretBrush="{DynamicResource ThemeDataGridHdr}"
                                     PasswordChar="●"
                                     KeyDown="RoomNumberBox_KeyDown"/>
                    </Border>
                </Grid>

                <!-- Join button -->
                <Button x:Name="BtnJoin"
                        Content="JOIN BB"
                        Click="Join_Click"
                        Margin="14,0,14,16"
                        Height="36"
                        Cursor="Hand"
                        FontSize="13" FontWeight="Black"
                        Foreground="White" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="4" BorderThickness="1"
                                    BorderBrush="{DynamicResource ThemeBtnBorder}"
                                    Background="{DynamicResource ThemeBtnBrush}">
                                <Border x:Name="Overlay" CornerRadius="4" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                </Border>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Overlay" Property="Background" Value="#20FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Overlay" Property="Background" Value="#30000000"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>

        <!-- Close button -->
        <Button x:Name="BtnClose" Click="BtnClose_Click"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Width="26" Height="26"
                Panel.ZIndex="20" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" CornerRadius="13" Background="#BB1111">
                        <TextBlock Text="✕" Foreground="White" FontSize="12" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#EE0000"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
