<Window x:Class="Skua.App.WPF.StatTrackerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stat Tracker"
        Height="470" Width="284"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Left="0" Top="0"
        Background="{DynamicResource ThemeBg}"
        FontFamily="Segoe UI">

    <Grid>
        <!-- Themed border frame -->
        <Border Margin="6" BorderThickness="2" CornerRadius="4"
                BorderBrush="{DynamicResource ThemeBorderBrush}">

            <StackPanel Background="{DynamicResource ThemeBg}">

                <!-- Title / drag header -->
                <Border Padding="12,8" Cursor="SizeAll" MouseLeftButtonDown="Window_MouseDown"
                        Background="{DynamicResource ThemeRowBg}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Stat Tracker"
                                   FontFamily="Georgia" FontStyle="Italic" FontSize="15"
                                   Foreground="{DynamicResource ThemeTitle}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="6" Height="6" Fill="#23A55A"
                                     Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="LIVE" Foreground="#23A55A"
                                       FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Divider -->
                <Border Height="1" Background="{DynamicResource ThemeDividerBrush}"/>

                <!-- Stat rows (accent colors are semantic — unchanged across themes) -->
                <StackPanel Margin="8,6,8,4">

                    <Border Background="{DynamicResource ThemeRowBg}" CornerRadius="4" Margin="0,2"
                            Padding="10,7,6,7" BorderThickness="3,0,0,0" BorderBrush="#ED4245">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Deaths" Foreground="{DynamicResource ThemeRowLabel}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Deaths}" Foreground="{DynamicResource ThemeTitle}"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content="↺" Command="{Binding ResetDeathsCommand}"
                                    Background="Transparent" BorderThickness="0" Foreground="{DynamicResource ThemeSubLabel}"
                                    FontSize="13" Cursor="Hand" ToolTip="Reset deaths"/>
                        </Grid>
                    </Border>

                    <Border Background="{DynamicResource ThemeRowBg}" CornerRadius="4" Margin="0,2"
                            Padding="10,7,6,7" BorderThickness="3,0,0,0" BorderBrush="#23A55A">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Kills" Foreground="{DynamicResource ThemeRowLabel}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Kills}" Foreground="{DynamicResource ThemeTitle}"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content="↺" Command="{Binding ResetKillsCommand}"
                                    Background="Transparent" BorderThickness="0" Foreground="{DynamicResource ThemeSubLabel}"
                                    FontSize="13" Cursor="Hand" ToolTip="Reset kills"/>
                        </Grid>
                    </Border>

                    <Border Background="{DynamicResource ThemeRowBg}" CornerRadius="4" Margin="0,2"
                            Padding="10,7,6,7" BorderThickness="3,0,0,0" BorderBrush="#5865F2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Dmg Taken" Foreground="{DynamicResource ThemeRowLabel}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding DamageTakenDisplay}" Foreground="{DynamicResource ThemeTitle}"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content="↺" Command="{Binding ResetDamageTakenCommand}"
                                    Background="Transparent" BorderThickness="0" Foreground="{DynamicResource ThemeSubLabel}"
                                    FontSize="13" Cursor="Hand" ToolTip="Reset damage taken"/>
                        </Grid>
                    </Border>

                    <Border Background="{DynamicResource ThemeRowBg}" CornerRadius="4" Margin="0,2"
                            Padding="10,7,6,7" BorderThickness="3,0,0,0" BorderBrush="#5865F2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Dmg Dealt" Foreground="{DynamicResource ThemeRowLabel}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding DamageDealtDisplay}" Foreground="{DynamicResource ThemeTitle}"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content="↺" Command="{Binding ResetDamageDealtCommand}"
                                    Background="Transparent" BorderThickness="0" Foreground="{DynamicResource ThemeSubLabel}"
                                    FontSize="13" Cursor="Hand" ToolTip="Reset damage dealt"/>
                        </Grid>
                    </Border>

                    <Border Background="{DynamicResource ThemeRowBg}" CornerRadius="4" Margin="0,2"
                            Padding="10,7,6,7" BorderThickness="3,0,0,0" BorderBrush="#1ABC9C">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Heals" Foreground="{DynamicResource ThemeRowLabel}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding HealsReceivedDisplay}" Foreground="{DynamicResource ThemeTitle}"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content="↺" Command="{Binding ResetHealsCommand}"
                                    Background="Transparent" BorderThickness="0" Foreground="{DynamicResource ThemeSubLabel}"
                                    FontSize="13" Cursor="Hand" ToolTip="Reset heals"/>
                        </Grid>
                    </Border>

                    <Border Background="{DynamicResource ThemeRowBg}" CornerRadius="4" Margin="0,2"
                            Padding="10,7,6,7" BorderThickness="3,0,0,0" BorderBrush="#FFA726">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Crits" Foreground="{DynamicResource ThemeRowLabel}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Crits}" Foreground="{DynamicResource ThemeTitle}"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content="↺" Command="{Binding ResetCritsCommand}"
                                    Background="Transparent" BorderThickness="0" Foreground="{DynamicResource ThemeSubLabel}"
                                    FontSize="13" Cursor="Hand" ToolTip="Reset crits"/>
                        </Grid>
                    </Border>

                    <Border Background="{DynamicResource ThemeRowBg}" CornerRadius="4" Margin="0,2"
                            Padding="10,7,6,7" BorderThickness="3,0,0,0" BorderBrush="#AB47BC">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Dodges" Foreground="{DynamicResource ThemeRowLabel}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Dodges}" Foreground="{DynamicResource ThemeTitle}"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content="↺" Command="{Binding ResetDodgesCommand}"
                                    Background="Transparent" BorderThickness="0" Foreground="{DynamicResource ThemeSubLabel}"
                                    FontSize="13" Cursor="Hand" ToolTip="Reset dodges"/>
                        </Grid>
                    </Border>

                </StackPanel>

                <!-- Mid divider -->
                <Border Height="1" Margin="8,4" Background="{DynamicResource ThemeSectionDivBrush}"/>

                <!-- Footer buttons -->
                <Grid Margin="8,0,8,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Reset All" Command="{Binding ResetAllCommand}"
                            Height="30" BorderThickness="0" Cursor="Hand"
                            FontSize="12" FontWeight="SemiBold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="3" BorderThickness="1"
                                        BorderBrush="{DynamicResource ThemeBtnBorder}"
                                        Background="{DynamicResource ThemeBtnBrush}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      TextElement.Foreground="{DynamicResource ThemeBg}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="2" Content="Skills" Click="SkillsButton_Click"
                            Height="30" BorderThickness="0" Cursor="Hand"
                            FontSize="12" FontWeight="SemiBold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="3" BorderThickness="1"
                                        BorderBrush="{DynamicResource ThemeRowBtnBorder}"
                                        Background="{DynamicResource ThemeRowBtnBg}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      TextElement.Foreground="{DynamicResource ThemeRowBtnFg}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ThemeRowBtnHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

            </StackPanel>
        </Border>
    </Grid>
</Window>
