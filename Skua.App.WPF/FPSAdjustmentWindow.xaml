<Window x:Class="Skua.App.WPF.FPSAdjustmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PVP FPS"
        Height="230" Width="300"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False"
        Icon="{x:Null}"
        Background="{DynamicResource ThemeBg}"
        FontFamily="Segoe UI">

    <Grid>
        <!-- Ornate border -->
        <Border Margin="10" BorderThickness="3" CornerRadius="4"
                BorderBrush="{DynamicResource ThemeBorderBrush}">

            <StackPanel Background="{DynamicResource ThemeBg}">

                <!-- Title / drag handle -->
                <Border Background="Transparent" Cursor="SizeAll"
                        MouseLeftButtonDown="Window_MouseDown" Padding="0,14,0,6">
                    <TextBlock Text="PVP FPS"
                               FontFamily="Georgia" FontStyle="Italic" FontSize="19"
                               Foreground="{DynamicResource ThemeTitle}" HorizontalAlignment="Center"/>
                </Border>

                <!-- Divider -->
                <Border Height="1" Margin="16,0,16,12"
                        Background="{DynamicResource ThemeDividerBrush}"/>

                <!-- Warning -->
                <TextBlock Foreground="{DynamicResource ThemeSubLabel}" FontSize="10"
                           TextWrapping="Wrap" Margin="16,0,16,14" LineHeight="15">
                    Regular AQW FPS = 24. Higher FPS may cause door lag.
                </TextBlock>

                <!-- FPS label + value -->
                <Grid Margin="16,0,16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Target FPS"
                               Foreground="{DynamicResource ThemeRowLabel}" FontSize="12"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="FpsValueText" Text="24"
                               Foreground="{DynamicResource ThemeTitle}" FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Slider -->
                <Slider x:Name="FpsSlider"
                        Minimum="1" Maximum="60" Value="24"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Margin="16,0,16,16"
                        ValueChanged="FpsSlider_ValueChanged"/>

                <!-- Apply button -->
                <Button x:Name="BtnApply"
                        Content="APPLY"
                        Click="Apply_Click"
                        Margin="16,0,16,14"
                        Height="34"
                        Cursor="Hand"
                        FontSize="12" FontWeight="Black"
                        Foreground="White" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="4" BorderThickness="1"
                                    BorderBrush="{DynamicResource ThemeBtnBorder}"
                                    Background="{DynamicResource ThemeBtnBrush}">
                                <Border x:Name="Overlay" CornerRadius="4" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                </Border>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Overlay" Property="Background" Value="#20FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Overlay" Property="Background" Value="#30000000"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>

        <!-- Close button -->
        <Button x:Name="BtnClose" Click="BtnClose_Click"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Width="26" Height="26"
                Panel.ZIndex="20" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" CornerRadius="13" Background="#BB1111">
                        <TextBlock Text="✕" Foreground="White" FontSize="12" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#EE0000"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
