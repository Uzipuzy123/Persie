<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark (default) ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ThemeBg"             Color="#080808"/>
    <SolidColorBrush x:Key="ThemeRowBg"          Color="#0D0D0D"/>
    <SolidColorBrush x:Key="ThemeSubBg"          Color="#0A0A0A"/>
    <SolidColorBrush x:Key="ThemeDivider"        Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ThemeSectionDiv"     Color="#2A1E08"/>
    <SolidColorBrush x:Key="ThemeSectionLabel"   Color="#7A5C18"/>
    <SolidColorBrush x:Key="ThemeArrow"          Color="#992222"/>
    <SolidColorBrush x:Key="ThemeTitle"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThemeRowLabel"       Color="#CCCCCC"/>
    <SolidColorBrush x:Key="ThemeSubLabel"       Color="#555555"/>
    <SolidColorBrush x:Key="ThemeBtnBorder"      Color="#E8C870"/>
    <SolidColorBrush x:Key="ThemeDataGridHdr"    Color="#C8A040"/>
    <SolidColorBrush x:Key="ThemeDataGridSep"    Color="#2A1E08"/>
    <SolidColorBrush x:Key="ThemeDataGridHover"  Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ThemeDataGridSel"    Color="#2A1E08"/>
    <SolidColorBrush x:Key="ThemeDataGridAlt"    Color="#111111"/>
    <SolidColorBrush x:Key="ThemeRowBtnBg"       Color="#0D0D0D"/>
    <SolidColorBrush x:Key="ThemeRowBtnFg"       Color="#AAAAAA"/>
    <SolidColorBrush x:Key="ThemeRowBtnBorder"   Color="#2A1E08"/>
    <SolidColorBrush x:Key="ThemeRowBtnHover"    Color="#C8A040"/>

    <LinearGradientBrush x:Key="ThemeBorderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#C8A040" Offset="0"/>
        <GradientStop Color="#8B6318" Offset="0.5"/>
        <GradientStop Color="#C8A040" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ThemeDividerBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="Transparent" Offset="0"/>
        <GradientStop Color="#C8A040"     Offset="0.3"/>
        <GradientStop Color="#C8A040"     Offset="0.7"/>
        <GradientStop Color="Transparent" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ThemeSectionDivBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="Transparent" Offset="0"/>
        <GradientStop Color="#2A1E08"     Offset="0.3"/>
        <GradientStop Color="#2A1E08"     Offset="0.7"/>
        <GradientStop Color="Transparent" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ThemeBtnBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#C8A040" Offset="0"/>
        <GradientStop Color="#7A5C10" Offset="1"/>
    </LinearGradientBrush>

    <!-- Browser chrome ──────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ThemeChromeBg"           Color="#202124"/>
    <SolidColorBrush x:Key="ThemeChromeActiveTab"    Color="#35363A"/>
    <SolidColorBrush x:Key="ThemeChromeTitle"        Color="#E8EAED"/>
    <SolidColorBrush x:Key="ThemeChromeIcon"         Color="#9AA0A6"/>
    <SolidColorBrush x:Key="ThemeChromeBorder"       Color="#3C4043"/>
    <SolidColorBrush x:Key="ThemeChromeAddressBg"    Color="#303134"/>
    <SolidColorBrush x:Key="ThemeChromeAddressText"  Color="#E8EAED"/>
    <SolidColorBrush x:Key="ThemeChromeNavHover"     Color="#3C4043"/>
    <SolidColorBrush x:Key="ThemeChromeNavPressed"   Color="#4A4B4E"/>
    <SolidColorBrush x:Key="ThemeChromeBookmarkText" Color="#9AA0A6"/>

</ResourceDictionary>
