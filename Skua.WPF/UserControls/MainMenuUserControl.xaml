<UserControl
    x:Class="Skua.WPF.UserControls.MainMenuUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Skua.WPF.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:materialdesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vms="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core"
    d:DataContext="{d:DesignInstance vms:MainMenuViewModel}"
    d:DesignHeight="72"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>

        <!-- Round nav icon button -->
        <Style x:Key="NavIconBtn" TargetType="Button">
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource ThemeChromeIcon}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeChromeNavHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeChromeNavPressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bookmark bar item: toggle (Stats, PVP Settings, BB Join, Theme) -->
        <Style x:Key="BookmarkToggle" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource ThemeChromeBookmarkText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialdesign:PackIcon x:Name="Icon" Kind="StarFourPoints"
                                                         Width="13" Height="13"
                                                         Foreground="{DynamicResource ThemeChromeIcon}"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,4,0"/>
                                <ContentPresenter VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeChromeNavHover}"/>
                                <Setter Property="Foreground" Value="#1A73E8"/>
                                <Setter TargetName="Icon" Property="Foreground" Value="#1A73E8"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked"   Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeChromeNavHover}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bookmark bar item: regular button (PVP FPS) -->
        <Style x:Key="BookmarkBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource ThemeChromeBookmarkText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialdesign:PackIcon Kind="StarFourPoints"
                                                         Width="13" Height="13"
                                                         Foreground="{DynamicResource ThemeChromeIcon}"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,4,0"/>
                                <ContentPresenter VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeChromeNavHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeChromeNavPressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <StackPanel>

        <!-- ── Address bar row ──────────────────────────────────────────── -->
        <Border Height="44" Background="{DynamicResource ThemeChromeBg}"
                BorderBrush="{DynamicResource ThemeChromeBorder}" BorderThickness="0,0,0,1">
            <Grid Margin="6,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Back / Forward / Refresh -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,4,0">
                    <Button Style="{StaticResource NavIconBtn}" ToolTip="Back">
                        <materialdesign:PackIcon Kind="ArrowLeft" Width="16" Height="16"/>
                    </Button>
                    <Button Style="{StaticResource NavIconBtn}" ToolTip="Forward" Margin="2,0,0,0">
                        <materialdesign:PackIcon Kind="ArrowRight" Width="16" Height="16"/>
                    </Button>
                    <Button Style="{StaticResource NavIconBtn}" ToolTip="Reload" Margin="2,0,0,0">
                        <materialdesign:PackIcon Kind="Refresh" Width="16" Height="16"/>
                    </Button>
                </StackPanel>

                <!-- Address bar -->
                <Border Grid.Column="1" Background="{DynamicResource ThemeChromeAddressBg}" CornerRadius="22"
                        Margin="6,6,6,6" Padding="12,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.08"
                                          BlurRadius="4" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialdesign:PackIcon Kind="Lock" Width="13" Height="13"
                                                  Foreground="#1E8E3E"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,6,0"/>
                        <TextBlock Text="https://game.aq.com/game/gamefiles/Loader3.swf"
                                   Foreground="{DynamicResource ThemeChromeAddressText}"
                                   FontFamily="Segoe UI" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Right side: bookmark star + LIVE -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,4,0">
                    <Button Style="{StaticResource NavIconBtn}" ToolTip="Bookmark">
                        <materialdesign:PackIcon Kind="StarOutline" Width="16" Height="16"/>
                    </Button>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                        <Ellipse Width="7" Height="7" Fill="#23A55A"
                                 Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="LIVE" Foreground="#23A55A"
                                   FontSize="10" FontWeight="Bold"
                                   FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Bookmarks bar row ─────────────────────────────────────────── -->
        <Border Height="30" Background="{DynamicResource ThemeChromeBg}"
                BorderBrush="{DynamicResource ThemeChromeBorder}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">

                <ToggleButton
                    Content="Stats"
                    IsChecked="{Binding IsStatTrackerOpen, Mode=TwoWay}"
                    Style="{StaticResource BookmarkToggle}"/>

                <ToggleButton
                    Content="Perf"
                    IsChecked="{Binding IsPerfOpen, Mode=TwoWay}"
                    Style="{StaticResource BookmarkToggle}"
                    Margin="2,0,0,0"/>

                <ToggleButton
                    Content="PVP FPS"
                    IsChecked="{Binding IsFPSOpen, Mode=TwoWay}"
                    Style="{StaticResource BookmarkToggle}"
                    Margin="2,0,0,0"/>

                <ToggleButton
                    Content="PVP Settings"
                    IsChecked="{Binding IsQualityOpen, Mode=TwoWay}"
                    Style="{StaticResource BookmarkToggle}"
                    Margin="2,0,0,0"/>

                <ToggleButton
                    Content="BB Join"
                    IsChecked="{Binding IsBBOpen, Mode=TwoWay}"
                    Style="{StaticResource BookmarkToggle}"
                    Margin="2,0,0,0"/>

                <ToggleButton
                    Content="Theme"
                    IsChecked="{Binding IsThemeOpen, Mode=TwoWay}"
                    Style="{StaticResource BookmarkToggle}"
                    Margin="2,0,0,0"/>

                <Button
                    Content="HQ"
                    Command="{Binding JoinHQCommand}"
                    Style="{StaticResource BookmarkBtn}"
                    Margin="2,0,0,0"/>

                <ToggleButton
                    Content="Scoreboard"
                    IsChecked="{Binding IsScoreboardOpen, Mode=TwoWay}"
                    Style="{StaticResource BookmarkToggle}"
                    Margin="2,0,0,0"/>

            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
