<Window x:Class="Skua.App.WPF.SkillBreakdownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Skill Breakdown"
        Height="360" Width="560"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Left="290" Top="0"
        Background="{DynamicResource ThemeBg}"
        FontFamily="Segoe UI"
        MouseLeftButtonDown="Window_MouseDown">

    <Grid>
        <!-- Themed border frame -->
        <Border Margin="6" BorderThickness="2" CornerRadius="4"
                BorderBrush="{DynamicResource ThemeBorderBrush}">

            <StackPanel Background="{DynamicResource ThemeBg}">

                <!-- Title / drag header -->
                <Border Padding="12,8" Background="{DynamicResource ThemeRowBg}" Cursor="SizeAll"
                        MouseLeftButtonDown="Window_MouseDown">
                    <TextBlock Text="Skill Breakdown"
                               FontFamily="Georgia" FontStyle="Italic" FontSize="15"
                               Foreground="{DynamicResource ThemeTitle}"/>
                </Border>

                <!-- Divider -->
                <Border Height="1" Background="{DynamicResource ThemeDividerBrush}"/>

                <!-- Data grid -->
                <DataGrid ItemsSource="{Binding Skills}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          Background="{DynamicResource ThemeBg}"
                          RowBackground="{DynamicResource ThemeRowBg}"
                          AlternatingRowBackground="{DynamicResource ThemeDataGridAlt}"
                          Foreground="{DynamicResource ThemeRowLabel}"
                          FontSize="12"
                          BorderThickness="0"
                          Margin="8,6,8,0"
                          ColumnHeaderHeight="26"
                          RowHeight="28">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"      Value="{DynamicResource ThemeRowBg}"/>
                            <Setter Property="Foreground"      Value="{DynamicResource ThemeDataGridHdr}"/>
                            <Setter Property="FontSize"        Value="11"/>
                            <Setter Property="FontWeight"      Value="SemiBold"/>
                            <Setter Property="Padding"         Value="8,4"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="SeparatorBrush"  Value="{DynamicResource ThemeDataGridSep}"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ThemeDataGridHover}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ThemeDataGridSel}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding"         Value="0"/>
                            <Setter Property="Foreground"      Value="{DynamicResource ThemeRowLabel}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="8,0" Background="Transparent">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Skill"     Binding="{Binding Name}"                               Width="140"/>
                        <DataGridTextColumn Header="Total Dmg" Binding="{Binding TotalDamage, StringFormat={}{0:N0}}" Width="85"/>
                        <DataGridTextColumn Header="Avg Dmg"   Binding="{Binding AvgDamage}"                          Width="75"/>
                        <DataGridTextColumn Header="Uses"      Binding="{Binding Uses}"                               Width="50"/>
                        <DataGridTextColumn Header="Crits"     Binding="{Binding Crits}"                              Width="50"/>
                        <DataGridTextColumn Header="Crit%"     Binding="{Binding CritRate}"                           Width="55"/>
                        <DataGridTextColumn Header="Kills"     Binding="{Binding Kills}"                              Width="50"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Reset button -->
                <Button Content="Reset" Click="ResetButton_Click"
                        Margin="8,8,8,10" Height="30"
                        BorderThickness="0" Cursor="Hand"
                        FontSize="12" FontWeight="SemiBold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="3" BorderThickness="1"
                                    BorderBrush="{DynamicResource ThemeBtnBorder}"
                                    Background="{DynamicResource ThemeBtnBrush}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  TextElement.Foreground="{DynamicResource ThemeBg}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>

        <!-- Close button -->
        <Button Click="BtnClose_Click"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Width="24" Height="24"
                Panel.ZIndex="20" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" CornerRadius="12" Background="#BB1111">
                        <TextBlock Text="✕" Foreground="White" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#EE0000"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
